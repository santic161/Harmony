{
  "name": "agentic-decision",
  "version": "0.1.0",
  "description": "Production-grade agentic decision workflows with async human-in-the-loop via LLMs and messaging channels.",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    },
    "./internal": {
      "types": "./dist/internal.d.ts",
      "import": "./dist/internal.js",
      "default": "./dist/internal.js"
    },
    "./llm.txt": "./llm.txt",
    "./package.json": "./package.json"
  },
  "files": [
    "dist",
    "llm.txt",
    "LICENSE"
  ],
  "sideEffects": false,
  "engines": {
    "node": ">=20"
  },
  "packageManager": "pnpm@10.13.1",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "demo:local": "node --import tsx examples/local-console.ts",
    "demo:actions": "node --import tsx examples/local-actions-console.ts",
    "demo:telegram": "node --env-file=.env --import tsx examples/basic-telegram.ts",
    "demo:fallback": "node --env-file=.env --import tsx examples/multi-provider-fallback.ts",
    "demo:whatsapp": "node --env-file=.env --import tsx examples/whatsapp-stub.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "lint": "eslint .",
    "format": "prettier --write .",
    "verify": "pnpm typecheck && pnpm lint && pnpm test && pnpm build",
    "pack:check": "npm pack --dry-run",
    "prepublishOnly": "pnpm verify"
  },
  "keywords": [
    "agent",
    "llm",
    "decision",
    "workflow",
    "human-in-the-loop",
    "openai",
    "anthropic",
    "gemini",
    "telegram",
    "whatsapp"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "nanoid": "^5.0.7",
    "pino": "^9.5.0",
    "zod": "^3.23.8"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "@google/generative-ai": "^0.21.0",
    "ioredis": "^5.4.1",
    "node-telegram-bot-api": "^0.66.0",
    "openai": "^4.67.0"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "@google/generative-ai": {
      "optional": true
    },
    "ioredis": {
      "optional": true
    },
    "node-telegram-bot-api": {
      "optional": true
    },
    "openai": {
      "optional": true
    }
  },
  "devDependencies": {
    "@anthropic-ai/sdk": "^0.32.0",
    "@eslint/js": "^9.25.1",
    "@google/generative-ai": "^0.21.0",
    "@types/node": "^22.9.0",
    "@types/node-telegram-bot-api": "^0.64.7",
    "@types/qrcode-terminal": "^0.12.2",
    "eslint": "^9.25.1",
    "globals": "^16.0.0",
    "ioredis": "^5.4.1",
    "node-telegram-bot-api": "^0.66.0",
    "openai": "^4.67.0",
    "pino-pretty": "^13.1.3",
    "prettier": "^3.3.3",
    "qrcode-terminal": "^0.12.0",
    "tsup": "^8.3.5",
    "tsx": "^4.21.0",
    "typescript": "^5.6.3",
    "typescript-eslint": "^8.30.1",
    "vitest": "^2.1.4",
    "whatsapp-web.js": "^1.34.6"
  }
}
